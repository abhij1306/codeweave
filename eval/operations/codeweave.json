{
  "repo": "codeweave",
  "note": "Production code_retrieve operations migrated from the retired ranker suite plus reference and contract regressions.",
  "cases": [
    {
      "id": "find-file-cargo",
      "category": "find-file",
      "operation": {"operation": "find_file", "name": "Cargo.toml", "max_results": 10},
      "expected_paths": ["Cargo.toml"]
    },
    {
      "id": "find-file-config-example",
      "category": "find-file",
      "operation": {"operation": "find_file", "name": "config.example.json", "max_results": 10},
      "expected_paths": ["config.example.json"]
    },
    {
      "id": "find-file-workspace-tests",
      "category": "find-file",
      "operation": {"operation": "find_file", "name": "workspace/tests.rs", "max_results": 10},
      "expected_paths": ["src/workspace/tests.rs"]
    },
    {
      "id": "find-symbol-resolve-access",
      "category": "find-symbol",
      "operation": {"operation": "find_symbol", "symbol": "resolve_access", "max_results": 10},
      "expected_paths": ["src/tools/mod.rs"]
    },
    {
      "id": "find-symbol-workspace-manager",
      "category": "find-symbol",
      "operation": {"operation": "find_symbol", "symbol": "WorkspaceManager", "max_results": 10},
      "expected_paths": ["src/manager.rs"]
    },
    {
      "id": "find-symbol-bash-supervisor",
      "category": "find-symbol",
      "operation": {"operation": "find_symbol", "symbol": "BashSupervisor", "max_results": 10},
      "expected_paths": ["src/bash.rs"]
    },
    {
      "id": "find-symbol-symbol-extractor",
      "category": "find-symbol",
      "operation": {"operation": "find_symbol", "symbol": "extract_symbols", "max_results": 10},
      "expected_paths": ["src/symbols.rs"]
    },
    {
      "id": "find-symbol-path-validator",
      "category": "find-symbol",
      "operation": {"operation": "find_symbol", "symbol": "validate_relative", "max_results": 10},
      "expected_paths": ["src/security.rs"]
    },
    {
      "id": "find-symbol-token-loader",
      "category": "find-symbol",
      "operation": {"operation": "find_symbol", "symbol": "load_or_create_bearer_token", "max_results": 10},
      "expected_paths": ["src/main.rs"]
    },
    {
      "id": "find-symbol-git-backend",
      "category": "find-symbol",
      "operation": {"operation": "find_symbol", "symbol": "CliGitBackend", "max_results": 10},
      "expected_paths": ["src/repository.rs"]
    },
    {
      "id": "find-symbol-edit-engine",
      "category": "find-symbol",
      "operation": {"operation": "find_symbol", "symbol": "code_edit", "max_results": 10},
      "expected_paths": ["src/workspace/edit.rs"]
    },
    {
      "id": "literal-index-cache-schema",
      "category": "search-text",
      "operation": {"operation": "search_text", "pattern": "codeweave-index-v9", "max_results": 10},
      "expected_paths": ["src/index/scan.rs"]
    },
    {
      "id": "literal-http-transport",
      "category": "search-text",
      "operation": {"operation": "search_text", "pattern": "StreamableHttpService", "max_results": 10},
      "expected_paths": ["src/mcp_transport.rs"]
    },
    {
      "id": "literal-shared-dispatcher",
      "category": "search-text",
      "operation": {"operation": "search_text", "pattern": "prepare_retrieval_operation", "max_results": 20},
      "expected_paths": ["src/retrieval.rs"]
    },
    {
      "id": "regex-public-schema-payload",
      "category": "search-regex",
      "operation": {"operation": "search_text", "pattern": "pub\\s+fn\\s+full_list_payload", "syntax": "regex", "max_results": 10},
      "expected_paths": ["src/tools/mod.rs"]
    },
    {
      "id": "symbols-overview-retrieval",
      "category": "symbols-overview",
      "operation": {"operation": "symbols_overview", "paths": ["src/retrieval.rs"], "max_results": 50},
      "expected_paths": ["src/retrieval.rs"]
    },
    {
      "id": "symbols-overview-edit-engine",
      "category": "symbols-overview",
      "operation": {"operation": "symbols_overview", "paths": ["src/workspace/edit.rs"], "max_results": 100},
      "expected_paths": ["src/workspace/edit.rs"]
    },
    {
      "id": "repo-map-root",
      "category": "repo-map",
      "operation": {"operation": "repo_map", "path": ".", "max_results": 50},
      "expected_paths": []
    },
    {
      "id": "repo-map-index-scope",
      "category": "repo-map-scope",
      "operation": {"operation": "repo_map", "path": "src/index", "max_results": 50},
      "expected_paths": []
    },
    {
      "id": "reference-shared-dispatcher",
      "category": "find-references",
      "operation": {"operation": "find_references", "symbol": "execute_index_search", "definition_path": "src/retrieval.rs", "max_results": 20},
      "expected_paths": ["src/workspace/mod.rs"]
    },
    {
      "id": "reference-receiver-qualified-validation",
      "category": "find-references",
      "operation": {"operation": "find_references", "symbol": "run_edit_validation", "definition_path": "src/workspace/validation.rs", "max_results": 20},
      "expected_paths": ["src/workspace/edit.rs"]
    }
  ]
}
