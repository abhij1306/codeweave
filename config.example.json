{
  "server": {
    "host": "127.0.0.1",
    "port": 8813,
    "authMode": "bearer",
    "tokenFile": ".mcp-token",
    "statefulMode": true,
    "jsonResponse": false,
    "allowedHosts": [],
    "allowedOrigins": []
  },
  "workspace": {
    "defaultPath": "/path/to/projects/example",
    "allowedRoots": [
      "/path/to/projects"
    ],
    "artifactPaths": [
      "artifacts"
    ]
  },
  "skills": {
    "enabled": false,
    "roots": [],
    "explicitOnly": true
  },
  "policy": {
    "maxFileBytes": 2000000,
    "maxContextChars": 50000,
    "maxSearchResults": 100,
    "maxTaskOutputChars": 30000,
    "shellEnabled": false,
    "allowedCommands": [
      "git",
      "rg",
      "node",
      "npm",
      "npx",
      "pnpm",
      "python",
      "pytest",
      "cargo"
    ]
  },
  "tasks": {
    "test": {
      "command": [
        ".venv\\Scripts\\python.exe",
        "-m",
        "pytest",
        "tests",
        "-q",
        "--tb=short"
      ],
      "cwd": "backend",
      "timeoutMs": 300000,
      "background": false,
      "outputFilter": {
        "type": "failedTail",
        "chars": 30000
      }
    },
    "check": {
      "command": [
        ".venv\\Scripts\\python.exe",
        "-m",
        "ruff",
        "check",
        "app"
      ],
      "cwd": "backend",
      "timeoutMs": 120000
    }
  }
}
