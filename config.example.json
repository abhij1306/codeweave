{
  "configVersion": 2,
  "server": {
    "host": "127.0.0.1",
    "port": 8813,
    "authMode": "bearer",
    "tokenFile": ".mcp-token",
    "idleTimeoutMs": 5000,
    "allowedHosts": [
      "localhost",
      "127.0.0.1",
      "::1",
      "codeweave.example.com"
     ],
    "allowedOrigins": []
  },
  "workspace": {
    "path": "/path/to/projects/example",
    "artifactPaths": [
      "artifacts"
    ],
    "excludePaths": [
      "**/__pycache__/",
      "**/.pytest_cache/",
      "**/.pytest-tmp/",
      "**/.mypy_cache/",
      "**/.ruff_cache/",
      "*.log"
    ]
  },
  "intelligence": {
    "rust": {
      "enabled": false,
      "command": "rust-analyzer",
      "args": [],
      "timeoutMs": 10000
    },
    "python": {
      "enabled": false,
      "command": "basedpyright-langserver",
      "args": ["--stdio"],
      "timeoutMs": 10000
    },
    "typescript": {
      "enabled": false,
      "command": "typescript-language-server",
      "args": ["--stdio"],
      "timeoutMs": 10000
    }
  },
  "policy": {
    "maxFileBytes": 2000000,
    "maxContextChars": 50000,
    "maxSearchResults": 100,
    "bash": {
      "executable": "bash",
      "defaultTimeoutMs": 120000,
      "foregroundBudgetMs": 20000,
      "maxTimeoutMs": 300000,
      "maxOutputChars": 30000
    }
  }
}
